{
  "routes": [
    "/",
    "/blog",
    "/docs"
  ],
  "desktopRoutes": [
    "/products/featured"
  ],
  "mobileRoutes": [
    "/docs/getting-started"
  ],
  "dynamicRoutes": {
    "/blog/[slug]": [
      "/blog/launch-notes"
    ],
    "/docs/[section]/[slug]": [
      "/docs/guides/setup"
    ]
  },
  "excludePrefixes": [
    "/api",
    "/admin"
  ],
  "excludeRoutes": [
    "/preview"
  ],
  "includeSitemap": false,
  "failOnUnresolvedDynamicRoutes": false
}
