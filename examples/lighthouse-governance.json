{
  "routes": [
    "/",
    "/blog",
    "/maps"
  ],
  "desktopRoutes": [
    "/maps/gta-6-interactive-map"
  ],
  "mobileRoutes": [
    "/maps/gta-6-interactive-map"
  ],
  "dynamicRoutes": {
    "/blog/[game]": [
      "/blog/gta6",
      "/blog/gta5"
    ],
    "/blog/[game]/[slug]": [
      "/blog/gta6/trailers"
    ]
  },
  "excludePrefixes": [
    "/api",
    "/admin"
  ],
  "excludeRoutes": [
    "/maps/editor"
  ],
  "includeSitemap": false,
  "failOnUnresolvedDynamicRoutes": false
}
